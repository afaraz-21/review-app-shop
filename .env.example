# ╔══════════════════════════════════════════╗
# ║   REVIEW SYSTEM — CONFIGURATION FILE    ║
# ╚══════════════════════════════════════════╝

# Shopify Store URL
# Example: my-store.myshopify.com
SHOPIFY_STORE=YOUR-STORE.myshopify.com

# Shopify Admin API Access Token
# Shopify Admin > Settings > Apps and sales channels > Develop apps
# > Create an app > Configure Admin API scopes:
#   write_price_rules, write_discounts — 
# > Install app > Copy "Admin API access token"
SHOPIFY_TOKEN=shpat_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Discount Settings
DISCOUNT_PERCENT=10
CODE_PREFIX=THANKS

# Server Port
PORT=3000

# Amazon Review URL
AMAZON_REVIEW_URL=https://www.amazon.com/review/create-review?asin=XXXXXXXXXX
